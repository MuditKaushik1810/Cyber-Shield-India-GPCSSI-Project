# Cyber Shield India — environment template
# Copy to .env and fill in real values. Do not commit .env.

# Required: Google AI Studio key for Gemini 2.5 (langchain-google-genai).
GOOGLE_API_KEY=your-google-api-key-here

# Optional: NewsAPI key for the dynamic media tier (newsapi.org).
NEWS_API_KEY=your-newsapi-key-here

# Optional: SerpAPI key for the dynamic OSINT tier (serpapi.com).
SERPAPI_API_KEY=your-serpapi-key-here

# Optional: HaveIBeenPwned v3 key for the OSINT Sandbox breach checker
# (haveibeenpwned.com/API/Key). Without it the breach tool runs in a clearly
# labelled offline-mock mode.
HIBP_API_KEY=your-hibp-api-key-here

# Optional: Hugging Face Inference API token for the OSINT deepfake detector
# (huggingface.co/settings/tokens). Without it, the deepfake tool still runs the
# deterministic Error-Level-Analysis layer and reports the remote layer as
# 'token not configured'. HUGGINGFACEHUB_API_TOKEN is also accepted.
HF_API_TOKEN=your-hf-inference-token-here

# Optional: override the default HF deepfake image-classification model.
HF_DEEPFAKE_MODEL=prithivirajdamodaran/deepfake-image-detector
