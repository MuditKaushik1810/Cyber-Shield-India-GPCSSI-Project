# Cyber Shield India — environment template
# Copy to .env and fill in real values. Do NOT commit .env (it is git-ignored).
#   cp .env.example .env
# Only GOOGLE_API_KEY is required; every other value is optional and the app
# degrades gracefully when it is absent.

# =========================================================================== #
# REQUIRED                                                                     #
# =========================================================================== #

# Google AI Studio key for Gemini via langchain-google-genai — powers the
# 5-tier model cascade across every AI module (app + ingestion worker).
GOOGLE_API_KEY=your-google-api-key-here

# =========================================================================== #
# OPTIONAL — live web intelligence                                            #
# =========================================================================== #

# SerpAPI key (serpapi.com) — live web advisories, the OSINT identity search
# and web-augmented semantic answers.
SERPAPI_API_KEY=your-serpapi-key-here

# NewsAPI key (newsapi.org) — news / media aggregation tier used by the
# background harvester (python ingestion_worker.py).
NEWS_API_KEY=your-newsapi-key-here

# Google Programmable Search — reserved as an alternate web-search backend
# (config getters exist; not wired to a live path in the current build).
GOOGLE_CUSTOM_SEARCH_KEY=your-google-custom-search-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

# =========================================================================== #
# OPTIONAL — OSINT forensic layers                                            #
# =========================================================================== #

# HaveIBeenPwned v3 key (haveibeenpwned.com/API/Key) for breach checks. The
# identity analyzer works without it (email → XposedOrNot, domain → HIBP public
# breaches, both unauthenticated); this key only enables the legacy HIBP path.
HIBP_API_KEY=your-hibp-api-key-here

# Hugging Face Inference API token (huggingface.co/settings/tokens) for the
# remote deepfake classifier. Without it, the deepfake tool falls back to the
# local Error-Level-Analysis layer. HUGGINGFACEHUB_API_TOKEN is also accepted.
HF_API_TOKEN=your-hf-inference-token-here

# =========================================================================== #
# OPTIONAL — advanced overrides (sensible defaults ship in code; leave unset   #
# unless you specifically need to change them)                                 #
# =========================================================================== #

# Override the HF deepfake image-classification model id.
# HF_DEEPFAKE_MODEL=prithivirajdamodaran/deepfake-image-detector

# Override the HF inference endpoint base (defaults to the HF serverless router).
# HF_INFERENCE_BASE=https://router.huggingface.co/hf-inference/models

# Override the default Gemini model id used as the cascade's primary tier.
# GEMINI_MODEL=gemini-3.5-flash

# Remote quarterly case matrix for the Practice Lab (falls back to the bundled
# local baseline battery when unset or unreachable).
# REMOTE_LAB_URL=https://your-host/practice_lab/cycle_{cycle}_{year}.json
